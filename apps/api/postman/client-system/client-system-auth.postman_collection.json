{
  "info": {
    "name": "Event Planner API - Client System Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Client authentication endpoints: registration, login, and verification. Use client-system-local.postman_environment.json."
  },
  "item": [
    {
      "name": "Client Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"client@example.com\",\n  \"password\": \"123456\",\n  \"fullName\": \"John Doe\",\n  \"phoneNumber\": \"+1234567890\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/client-system/client/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "client-system", "client", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Registration response is valid', function () {",
              "    pm.expect(json.message).to.include('Registration successful');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Client Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{clientEmail}}\",\n  \"password\": \"{{clientPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/client-system/client/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "client-system", "client", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (json && json.token) {",
              "    pm.environment.set('clientToken', json.token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Client Verify",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{clientToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/client-system/client/verify",
          "host": ["{{baseUrl}}"],
          "path": ["api", "client-system", "client", "verify"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Verify response is valid', function () {",
              "    pm.expect(json.valid).to.eql(true);",
              "    pm.expect(json.client).to.be.an('object');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
