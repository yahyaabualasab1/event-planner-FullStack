{
  "info": {
    "name": "Event Planner API - Admin System Clients",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Client management endpoints for admin-system workflows."
  },
  "item": [
    {
      "name": "Create Client",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"new-client@example.com\",\n  \"password\": \"ClientPass123\",\n  \"fullName\": \"New Client\",\n  \"phoneNumber\": \"+1234567890\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/clients",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "clients"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Client was created', function () {",
              "    pm.expect(json).to.have.property('_id');",
              "});",
              "if (json && (json._id || json.id)) {",
              "    pm.environment.set('clientId', json._id || json.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get All Clients",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/clients",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "clients"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Response returns an array', function () {",
              "    pm.expect(json).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Client by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/clients/{{clientId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "clients",
            "{{clientId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Client response contains id', function () {",
              "    pm.expect(json).to.have.property('_id');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Update Client Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"approved\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/clients/{{clientId}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "clients",
            "{{clientId}}",
            "status"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Client status updated', function () {",
              "    pm.expect(json.status).to.eql('approved');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete Client",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/clients/{{clientId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "clients",
            "{{clientId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Client delete response contains message', function () {",
              "    pm.expect(json.message).to.eql('Client deleted successfully');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
