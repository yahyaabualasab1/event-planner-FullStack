{
  "info": {
    "name": "Event Planner API - Admin System Messages",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Admin message endpoints under /api/admin-system/messages. Use admin-system-local.postman_environment.json. Run Admin Login first to set adminToken."
  },
  "item": [
    {
      "name": "Create Message",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"senderId\": \"{{clientId}}\",\n  \"actorType\": \"admin\",\n  \"message\": \"Hello from admin.\",\n  \"threadId\": \"{{threadId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin-system/messages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin-system",
            "messages"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "if (json && (json._id || json.id)) {",
              "    pm.environment.set('messageId', json._id || json.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Messages by Thread",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin-system/messages/thread/{{threadId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin-system",
            "messages",
            "thread",
            "{{threadId}}"
          ]
        }
      }
    },
    {
      "name": "Get Messages by Sender",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin-system/messages/sender/{{senderId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin-system",
            "messages",
            "sender",
            "{{senderId}}"
          ]
        }
      }
    },
    {
      "name": "Get Message by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin-system/messages/{{messageId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin-system",
            "messages",
            "{{messageId}}"
          ]
        }
      }
    },
    {
      "name": "Update Message",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Updated message content.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin-system/messages/{{messageId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin-system",
            "messages",
            "{{messageId}}"
          ]
        }
      }
    },
    {
      "name": "Delete Message",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin-system/messages/{{messageId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin-system",
            "messages",
            "{{messageId}}"
          ]
        }
      }
    }
  ]
}
