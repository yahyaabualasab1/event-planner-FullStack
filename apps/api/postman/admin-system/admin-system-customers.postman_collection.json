{
  "info": {
    "name": "Event Planner API - Admin System Customers",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Admin customer CRUD under /api/admin-system/customers. Use admin-system-local.postman_environment.json. Run Admin Login (admin-system-auth) first to set adminToken."
  },
  "item": [
    {
      "name": "Get All Customers",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin-system/customers",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin-system", "customers"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Response is an array', function () {",
              "    pm.expect(json).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Customer By ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin-system/customers/{{customerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin-system", "customers", "{{customerId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Response has customer fields', function () {",
              "    pm.expect(json).to.have.property('_id');",
              "    pm.expect(json).to.have.property('email');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Customer",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"Password@123\",\n  \"fullName\": \"Test Customer\",\n  \"phoneNumber\": \"+970591234567\",\n  \"gender\": \"male\",\n  \"dob\": \"1995-01-01\",\n  \"city\": \"Nablus\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin-system/customers",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin-system", "customers"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "if (json && json._id) {",
              "    pm.environment.set('customerId', json._id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Update Customer",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Updated Customer Name\",\n  \"city\": \"Ramallah\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin-system/customers/{{customerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin-system", "customers", "{{customerId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Customer was updated', function () {",
              "    pm.expect(json.fullName).to.eql('Updated Customer Name');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete Customer",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin-system/customers/{{customerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin-system", "customers", "{{customerId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
