# API port (optional; defaults to 3000)
PORT=3000

# MongoDB — pick one:
# Local install (no Docker): start MongoDB service, then use:
MONGODB_URI=mongodb://127.0.0.1:27017/event-planner
# Or MongoDB Atlas — replace USER, PASS, cluster host, and DB name:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/event-planner?retryWrites=true&w=majority

# JWT signing secrets — use long random strings in production (never commit real .env)
JWT_ADMIN_SECRET=replace-with-long-random-admin-secret
JWT_CLIENT_SECRET=replace-with-long-random-client-secret
JWT_CUSTOMER_SECRET=replace-with-long-random-customer-secret
